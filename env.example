# PostgreSQL
POSTGRES_USER=callroute
POSTGRES_PASSWORD=callroute_secret
POSTGRES_DB=callroute_db
DATABASE_URL=postgresql+asyncpg://callroute:callroute_secret@postgres:5432/callroute_db

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# JWT
SECRET_KEY=supersecretkey_change_in_production_32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Billing
LOW_CONFIDENCE_THRESHOLD=0.55
DEFAULT_SIGNUP_BONUS=100

# Grafana
GRAFANA_PASSWORD=admin

# Model paths (inside container)
FAST_MODEL_PATH=/app/models/catboost_model.cbm
FAST_TFIDF_PATH=/app/models/tfidf.pkl
SMART_MODEL_PATH=/app/models/smart_model
